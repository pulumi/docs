{
  "metadata": [
    {
      "src": [
        {
          "src": "../../esc-sdk/sdk/csharp",
          "files": ["Pulumi.Esc.Sdk/Pulumi.Esc.Sdk.csproj"]
        }
      ],
      "dest": "metadata/Pulumi.Esc.Sdk"
    }
  ],
  "build": {
    "content": [
      {
        "src": "metadata",
        "files": ["**/*.yml"],
        "dest": "."
      }
    ],
    "overwrite": [],
    "dest": "../static-prebuilt/docs/reference/pkg/dotnet/esc-sdk",
    "globalMetadata": {
      "_appFooter": "Copyright 2016-2023, Pulumi Corporation."
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "./pulumi-template"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
