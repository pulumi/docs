{{- $pages := slice -}}
{{- range site.Data.docs_menu_sections -}}
  {{- with index site.Menus .menu -}}
    {{- $section := partial "cli-sitemap-walk.json" (dict "menuEntries" .) -}}
    {{- $pages = $pages | append $section -}}
  {{- end -}}
{{- end -}}
{{- dict "pages" $pages | jsonify (dict "indent" "  ") -}}
